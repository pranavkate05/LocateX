<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:background="@drawable/mybackground"
    tools:context=".ForgotPasswordActivity"

    >

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieforgot"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:lottie_autoPlay="true"
        app:lottie_rawRes="@raw/maparut"
        android:layout_marginTop="40dp"


        />




    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="35sp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        android:layout_margin="15pt"
        android:layout_gravity="center"


        >


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80FFFFFF"
            android:orientation="vertical"

            >


            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="15dp"
                android:fontFamily="@font/belgrano"
                android:text="Reset Your Password"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="20dp"
                android:textStyle="bold"

                />

            <EditText
                android:id="@+id/etForgotUsername"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:fontFamily="@font/chakra_petch_semibold"
                android:hint="Username/Mobile No."
                android:drawableLeft="@drawable/baseline_person_24"
                android:drawablePadding="10dp"
                android:inputType="text"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:background="@drawable/edittex_border"
                android:textSize="20sp"
                android:layout_margin="15dp"


                />




            <EditText
                android:id="@+id/etEnterNewPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:fontFamily="@font/chakra_petch_semibold"
                android:hint="Enter New Password"
                android:drawableLeft="@drawable/baseline_key_24"
                android:drawablePadding="10dp"
                android:inputType="textPassword"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:background="@drawable/edittex_border"
                android:textSize="20sp"
                android:layout_margin="15dp"


                />


            <EditText
                android:id="@+id/etRetypeNewPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_margin="15sp"
                android:drawableLeft="@drawable/baseline_key_24"
                android:drawablePadding="10dp"
                android:fontFamily="@font/chakra_petch_semibold"
                android:hint="Retype Your Password"
                android:inputType="textPassword"
                android:textColor="@color/black"
                android:background="@drawable/edittex_border"
                android:textColorHint="@color/black"
                android:textSize="20dp"


                />






            <Button
                android:id="@+id/btnForgotLogin"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:backgroundTint="#877E59"
                android:fontFamily="@font/averia_serif_libre_light"
                android:text="Continue"
                android:textColor="@color/black"
                android:textSize="20dp"
                android:textStyle="italic"
                android:layout_marginBottom="40sp"



                />


        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>